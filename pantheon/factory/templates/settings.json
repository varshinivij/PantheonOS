{
    "$schema": "https://pantheon.dev/schemas/settings.json",
    "version": "1.0.0",
    // ===== Environment File Configuration =====
    // Path to environment variables file, relative to project directory
    "env_file": ".env",
    // ===== Endpoint Service Configuration =====
    "endpoint": {
        "service_name": "pantheon-chatroom-endpoint",
        // Workspace: Endpoint's working directory (relative to PWD/Project root/Module load path)
        "workspace_path": ".",
        "log_level": "INFO",
        // Whether to allow file transfer through Endpoint
        "allow_file_transfer": true,
        // Local ToolSet call timeout (seconds)
        "local_toolset_timeout": 600,
        // Local ToolSet execution mode:
        // - "direct": Execute in current thread (fast, for lightweight tasks)
        // - "thread": Execute in separate thread (isolated, for heavy tasks)
        "local_toolset_execution_mode": "direct"
    },
    // ===== Built-in Services Configuration =====
    // Service modes: Specify service runtime modes
    // - "local": Run in Endpoint's process (fast, uses ThreadJob isolation)
    // - "remote": Run in separate process (slower, better isolation)
    "services": {
        "builtin": [
            // === Tier 1: Core Services (recommended for all deployments) ===
            "file_manager", // File operations (read, write, list, delete, etc.)
            "package", // Read-only access to available packages
            // === Tier 2: Common Development Tools ===
            "web", // Web search (using DDGS)
            "python_interpreter", // Python code execution
            "shell", // Shell command execution (use with caution)
            // "knowledge", // Knowledge base/RAG
            // === Tier 3: Advanced Tools (enable as needed) ===
            "integrated_notebook" // Integrated Notebook (with file operations)
            // === More Available Services (commented, enable as needed) ===
            // "file_editor",     // Advanced file editing (Claude Code style)
            // "jupyter_kernel",  // Standard Jupyter Kernel
            // "r_interpreter",   // R code execution
            // "julia_interpreter", // Julia code execution
            // "scraper",         // ScraperAPI search/scrape (requires API Key)
        ],
        // Service mode configuration
        // "default" is the default mode for services not explicitly specified
        "modes": {
            "default": "local"
            // "python_interpreter": "local",  // Lightweight services suit local
            // "julia_interpreter": "remote"   // Heavy computation may need isolation
        }
    },
    // ===== Remote Backend Configuration =====
    "remote": {
        // Remote backend type, currently only "nats" is supported
        "backend": "nats",
        // NATS server address list
        "nats_servers": [
            "nats://localhost:4222"
        ],
        // MCP server exposed hostname (use localhost for development)
        "server_host": "localhost"
    },
    // ===== ChatRoom Configuration =====
    "chatroom": {
        // Chat history storage directory
        "memory_dir": "./.pantheon/memory",
        // Enable NATS streaming (required for remote services)
        "enable_nats_streaming": false,
        // Speech-to-text model
        "speech_to_text_model": "gpt-4o-mini-transcribe"
    },
    // ===== REPL Configuration =====
    "repl": {
        // Disable log output
        "quiet": true,
        // Default team template path
        "default_template": null
    },
    // ===== API Keys Configuration =====
    // All API keys support environment variable override
    // Priority: environment variable > env_file > settings.json
    "api_keys": {
        "OPENAI_API_KEY": null,
        "OPENAI_API_BASE": null, // Custom OpenAI endpoint
        "ANTHROPIC_API_KEY": null,
        "GOOGLE_API_KEY": null,
        "ZAI_API_KEY": null,
        "SCRAPER_API_KEY": null, // ScraperAPI key
        "HUGGINGFACE_TOKEN": null
    },
    // ===== Knowledge/RAG Configuration =====
    "knowledge": {
        // Knowledge base storage path
        "storage_path": "~/.pantheon-knowledge",
        // Qdrant vector database configuration
        "qdrant": {
            "location": null, // Remote Qdrant URL
            "path": null, // Local storage path
            "api_key": null, // Qdrant Cloud API Key
            "prefer_grpc": false // Whether to prefer gRPC
        }
    },
    // ===== Model Selection Configuration =====
    // Smart model selection based on available API keys
    "models": {
        // Provider priority order (first available provider with API key is used)
        // "provider_priority": ["openai", "anthropic", "google", "zai", "deepseek"],

        // Per-provider model configuration (optional - code has sensible defaults)
        // Quality levels map to model lists (fallback chains)
        // "provider_models": {
        //     "openai": {
        //         "high": ["openai/gpt-4o", "openai/o1", "openai/gpt-4-turbo"],
        //         "normal": ["openai/gpt-4o-mini", "openai/gpt-4.1-mini"],
        //         "low": ["openai/gpt-3.5-turbo"]
        //     },
        //     "anthropic": {
        //         "high": ["anthropic/claude-opus-4-20250514", "anthropic/claude-sonnet-4-20250514"],
        //         "normal": ["anthropic/claude-sonnet-4-20250514", "anthropic/claude-3-5-sonnet-20241022"],
        //         "low": ["anthropic/claude-3-5-haiku-20241022"]
        //     }
        // }
    },
    // ===== ACE (Agentic Context Engineering) Configuration =====
    // ACE is a long-term memory system that learns from conversation trajectories
    "ace": {
        // Enable ACE learning system
        "enable": true,
        // LLM model for reflection and skill management
        // Must support structured output (response_format)
        "learning_model": "gpt-4o-mini",
        // Skillbook file path (relative to .pantheon/ace/)
        "skillbook_path": "skillbook.json",
        // Learning data directory (relative to .pantheon/ace/)
        "learning_dir": "learning",
        // Max skills per section (auto-evicts low-score skills when exceeded)
        "max_skills_per_section": 30,
        // Max characters for single skill content
        "max_content_length": 500,
        // Delete learning trajectory files after processing
        // Set to true in production for privacy/disk space
        "cleanup_after_learning": false,
        // Enable agent-specific skill scope filtering
        // If false, all agents see all skills (recommended for simpler setups)
        "enable_agent_scope": false
    }
}
{
    "$schema": "https://pantheon.dev/schemas/settings.json",
    "version": "1.0.0",
    // ===== Environment File Configuration =====
    // Path to environment variables file, relative to project directory
    "env_file": ".env",
    // ===== MCP Tools Configuration =====
    // Whether to auto-inject MCP tools (from unified gateway) into agents
    // For mcp abilities, this is not necessary, Package APIs are sufficient for all mcp tools
    "enable_mcp_tools": false,
    // Auto-overwrite agents/prompts/teams with latest factory defaults on startup. Set false to preserve user edits (settings.json and mcp.json are never overwritten).
    "default_template_auto_update": true,
    // ===== Endpoint Service Configuration =====
    "endpoint": {
        "service_name": "pantheon-chatroom-endpoint",
        // Workspace: Endpoint's working directory (relative to PWD/Project root/Module load path)
        "workspace_path": ".",
        "log_level": "INFO",
        // Whether to allow file transfer through Endpoint
        "allow_file_transfer": true,
        // Local ToolSet call timeout (seconds) - unified for Agent, ToolSetManager, and Kernel
        "local_toolset_timeout": 1800,
        // Local ToolSet execution mode:
        // - "direct": Execute in current thread (fast, for lightweight tasks)
        // - "thread": Execute in separate thread (isolated, for heavy tasks)
        "local_toolset_execution_mode": "direct",
        // === Tool Output Limits ===
        // Maximum characters for tool output (fallback; per-tool thresholds take priority)
        "max_tool_content_length": 50000,
        // Maximum lines for file read operations
        "max_file_read_lines": 1000,
        // Maximum characters for file read operations (safety valve; per-tool thresholds handle LLM sizing)
        "max_file_read_chars": 500000,
        // Maximum results for glob/search operations
        "max_glob_results": 50,
        // Enable notebook execution logging (JSONL files in .pantheon/logs/notebook/)
        "enable_notebook_execution_logging": true
    },
    // ===== Built-in Services Configuration =====
    // Service modes: Specify service runtime modes
    // - "local": Run in Endpoint's process (fast, uses ThreadJob isolation)
    // - "remote": Run in separate process (slower, better isolation)
    "services": {
        "builtin": [
            // === Tier 1: Core Services (recommended for all deployments) ===
            "file_manager", // File operations (read, write, list, delete, etc.)
            "package", // Read-only access to available packages
            // === Tier 2: Common Development Tools ===
            "web", // Web search (using DDGS)
            "python_interpreter", // Python code execution
            "shell", // Shell command execution (use with caution)
            // "knowledge", // Knowledge base/RAG
            // === Tier 3: Advanced Tools (enable as needed) ===
            "integrated_notebook", // Integrated Notebook (with file operations)
            "evolution"
            // === More Available Services (commented, enable as needed) ===
            // "file_editor",     // Advanced file editing (Claude Code style)
            // "jupyter_kernel",  // Standard Jupyter Kernel
            // "r_interpreter",   // R code execution
            // "julia_interpreter", // Julia code execution
            // "scraper",         // ScraperAPI search/scrape (requires API Key)
        ],
        // Service mode configuration
        // "default" is the default mode for services not explicitly specified
        "modes": {
            "default": "local"
            // "python_interpreter": "local",  // Lightweight services suit local
            // "julia_interpreter": "remote"   // Heavy computation may need isolation
        }
    },
    // ===== Remote Backend Configuration =====
    "remote": {
        // Remote backend type, currently only "nats" is supported
        "backend": "nats",
        // NATS server address list
        "nats_servers": [
            "nats://localhost:4222"
        ],
        // MCP server exposed hostname (use localhost for development)
        "server_host": "localhost"
    },
    // ===== ChatRoom Configuration =====
    "chatroom": {
        // Chat history storage directory
        "memory_dir": "./.pantheon/memory",
        // Enable NATS streaming (required for remote services)
        "enable_nats_streaming": false,
        // Speech-to-text model
        "speech_to_text_model": "gpt-4o-mini-transcribe"
    },
    // ===== REPL Configuration =====
    "repl": {
        // Disable log output
        "quiet": true,
        // Default team template path
        "default_template": null
    },
    // ===== API Keys Configuration =====
    // All API keys support environment variable override
    // Priority: environment variable > env_file > settings.json
    "api_keys": {
        "OPENAI_API_KEY": null,
        "OPENAI_API_BASE": null, // Custom OpenAI endpoint
        "ANTHROPIC_API_KEY": null,
        "GOOGLE_API_KEY": null,
        "ZAI_API_KEY": null,
        "SCRAPER_API_KEY": null, // ScraperAPI key
        "HUGGINGFACE_TOKEN": null
    },
    // ===== Knowledge/RAG Configuration =====
    "knowledge": {
        // Knowledge base storage path
        "storage_path": "~/.pantheon-knowledge",
        // Qdrant vector database configuration
        "qdrant": {
            "location": null, // Remote Qdrant URL
            "path": null, // Local storage path
            "api_key": null, // Qdrant Cloud API Key
            "prefer_grpc": false // Whether to prefer gRPC
        }
    },
    // ===== Model Selection Configuration =====
    // Smart model selection based on available API keys
    "models": {
        // Provider priority order (first available provider with API key is used)
        // "provider_priority": ["openai", "anthropic", "gemini", "zai", "deepseek"],
        // Per-provider model configuration (optional - code has sensible defaults)
        // Quality levels map to model lists (fallback chains)
        // "provider_models": {
        //     "openai": {
        //         "high": ["openai/gpt-5.4", "openai/gpt-5.2"],
        //         "normal": ["openai/gpt-5.4", "openai/gpt-5.2-codex", "openai/gpt-5.2", "openai/gpt-5"],
        //         "low": ["openai/gpt-5.4-mini", "openai/gpt-5.4-nano", "openai/gpt-5-mini", "openai/gpt-4.1-mini"]
        //     },
        //     "anthropic": {
        //         "high": ["anthropic/claude-opus-4-6", "anthropic/claude-opus-4-5-20251101"],
        //         "normal": ["anthropic/claude-sonnet-4-6", "anthropic/claude-sonnet-4-5-20250929"],
        //         "low": ["anthropic/claude-haiku-4-5"]
        //     },
        //     "gemini": {
        //         "high": ["gemini/gemini-3.1-pro-preview", "gemini/gemini-3-pro-preview", "gemini/gemini-2.5-pro"],
        //         "normal": ["gemini/gemini-3-flash-preview", "gemini/gemini-2.5-flash"],
        //         "low": ["gemini/gemini-3-flash-preview", "gemini/gemini-2.5-flash-lite"]
        //     }
        // }
    },
    // ===== Image Generation Configuration =====
    // Model selection for generate_image tool
    // Options: "high", "normal", "low", or specific model name
    // - "high": gemini/gemini-3-pro-image-preview (Nano Banana Pro, best quality)
    // - "normal": gemini/gemini-3.1-flash-image-preview (Nano Banana 2, fast)
    // - "low": gemini/gemini-2.5-flash-image (Nano Banana first-gen, stable)
    "image_gen_model": "normal",
    // Custom image generation models (optional - override code defaults)
    // "image_gen_models": {
    //     "gemini": {
    //         "high": ["gemini/gemini-3-pro-image-preview"],
    //         "normal": ["gemini/gemini-3-pro-image-preview"]
    //     },
    //     "openai": {
    //         "high": ["dall-e-3"],
    //         "normal": ["dall-e-3"]
    //     }
    // },
    // ===== Context Compression Configuration =====
    // Automatic context compression when approaching token limits
    "context_compression": {
        // Enable context compression (disabled by default)
        "enable": true,
        // LLM model for compression, Uses quality level: "high", "normal", "low", or specific model name
        "compression_model": "normal",
        // Trigger compression when token usage reaches this percentage (0.0-1.0)
        // TEST MODE: set to 0 to compress based on message count (min_messages_for_compression)
        "threshold": 0.8,
        // Number of recent messages to preserve uncompressed
        "preserve_recent_messages": 5,
        // Max length for individual tool argument values in compressed output
        "max_tool_arg_length": 1000,
        // Max length for tool output in compressed output
        "max_tool_output_length": 3000,
        // Wait this many messages before retrying after a compression failure
        "retry_after_messages": 10
    },
    // ===== Task System Configuration =====
    // Modal workflow tools (task_boundary, notify_user) for structured agent tasks
    "task_system": {
        // Enable the task system (injects TaskToolSet into primary agent)
        "enabled": true
    },
    // ===== Long-Term Memory System Configuration =====
    // Cross-session persistent memory with LLM-based selection and dream consolidation
    "memory_system": {
        // Enable the long-term memory system
        "enabled": true,
        // LLM model for memory selection (reads frontmatter, judges relevance)
        // Uses quality level: "high", "normal", "low", or specific model name
        "selection_model": "low",
        // Retrieval limits for memories and recent chats
        "selection_max_memories": 15,     // Max memories to select per query
        "selection_max_chats": 5,         // Max recent chats to select per query
        "session_notes_retrieval_limit": 15,  // Max session notes to scan (must be >= selection_max_chats)
        // Static index injection: inject MEMORY.md index into system prompt at startup.
        // Disabled by default — dynamic retrieval (on_run_start) handles context per query.
        // Enable if you want the agent to always see the full memory index.
        "static_index_enabled": false,
        // Dynamic retrieval injection mode:
        // - "index": inject title, summary, and file path only (default, low token cost)
        //   Agent can read the full file via file_manager if needed.
        // - "full": inject complete file content
        "inject_mode": "index",
        // Pre-compression flush: save important info to daily log before compression
        "flush_enabled": true,
        // Model for flush extraction (null = use selection_model)
        "flush_model": null,
        // Dream consolidation: periodic 4-phase memory distillation
        "dream_enabled": true,
        // Model for dream consolidation (null = use selection_model)
        "dream_model": null,
        // Minimum hours between dream consolidations
        "dream_min_hours": 24,
        // Minimum sessions before triggering dream
        "dream_min_sessions": 5,
        // Session note thresholds (for compact shortcut, uncomment to override defaults)
        // Min context tokens before first extraction (default: 10000)
        // "session_note_init_tokens": 10000,
        // Min token growth to trigger update (default: 5000)
        // "session_note_update_tokens": 5000,
        // Min tool calls to trigger update (default: 3)
        // "session_note_tool_calls": 3
    },
    // ===== Learning System Configuration =====
    // Procedural knowledge (skills) managed via skill_manage tool
    "learning_system": {
        // Enable the learning system (skill management + toolset)
        "enabled": true,
        // LLM model for skill operations
        // Uses quality level: "high", "normal", "low", or specific model name
        "model": "low",
        // Background auto-extraction (disabled by default, use skill_manage tool)
        "extract_enabled": false,
        // Model for skill extraction (null = use model above)
        "extract_model": null,
        // Extract skills every N runs (when extract_enabled=true)
        "extract_nudge_interval": 5,
        // Skills to disable (list of skill names)
        "disabled_skills": [],
        // Skill index injection limits (cap system prompt size)
        "skill_index_max_items": 50,    // Max number of skills listed in system prompt
        "skill_index_max_tokens": 2000  // Approx token budget for skill index
    },
    // ===== LLM Retry Configuration =====
    // Exponential backoff retry for transient LLM API errors (e.g., mid-stream overloaded)
    "llm_retry": {
        // Maximum number of retries per model before falling back to the next model
        "max_retries": 3,
        // Base delay in seconds (doubles each retry: ~1s, ~2s, ~4s)
        "base_delay": 1.0,
        // Maximum delay cap in seconds
        "max_delay": 30.0,
        // Jitter factor (0.0-1.0) to randomize delay and avoid thundering herd
        "jitter": 0.5
    }
}